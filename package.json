{
  "name": "boundaryless-workos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "api:dev": "node server/index.mjs",
    "api:migrate": "node server/migrate.mjs",
    "api:seed:demo": "node --import tsx server/seed-demo.mjs",
    "build": "vite build",
    "start": "node --import tsx server/start-production.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:requirements": "node --import tsx tests/requirements-smoke.mjs",
    "test:access": "node --import tsx tests/access-control-smoke.mjs",
    "test:leave": "node --import tsx tests/leave-management-smoke.mjs",
    "test:backend": "node tests/backend-contract-smoke.mjs",
    "test:approvals": "node --import tsx tests/approval-engine-smoke.mjs",
    "test:notifications": "node --import tsx tests/notification-center-smoke.mjs",
    "test:integrations": "node --import tsx tests/integration-adapters-smoke.mjs",
    "test:planning": "node --import tsx tests/resource-planning-smoke.mjs",
    "test:backend-api": "node tests/backend-api-smoke.mjs",
    "test:backend-roles": "node tests/backend-role-smoke.mjs",
    "test:import-templates": "node tests/import-template-smoke.mjs",
    "test:prod-hardening": "node tests/production-hardening-smoke.mjs",
    "test:prod-readiness": "node tests/prod-readiness.mjs"
  },
  "dependencies": {
    "@babel/compat-data": "^7.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
