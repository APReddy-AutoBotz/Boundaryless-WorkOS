# APP_URL: The URL where StaffPulse is hosted.
# Used for CORS, secure cookies, self-referential links, and future integration callbacks.
APP_URL="MY_APP_URL"

# APP_MODE / DISABLE_DEMO_FALLBACK:
# Use APP_MODE=demo locally when browser localStorage demo data is acceptable.
# Use APP_MODE=production and DISABLE_DEMO_FALLBACK=true for company production.
APP_MODE="demo"
DISABLE_DEMO_FALLBACK="false"

# PORT: Hosting provider runtime port. Render provides this automatically.
# Leave unset locally unless you specifically want one server port for production-mode testing.
PORT=10000

# API_PORT: Local backend API port. Ignored when PORT is set.
API_PORT=4000

# API_SESSION_SECRET: Required in production. Use a long random value.
API_SESSION_SECRET="replace-with-a-long-random-secret"

# LOGIN_RATE_LIMIT: Maximum failed/successful login attempts per username/IP window.
LOGIN_RATE_LIMIT=8

# DEMO_SEED_PASSWORD: Password assigned when running npm run api:seed:demo.
DEMO_SEED_PASSWORD="demo123"

# AUTO_MIGRATE / AUTO_SEED_DEMO: Optional deployment convenience flags.
# Useful on Render Free where an interactive shell is not available.
# Set both to true for the first demo deployment, then turn AUTO_SEED_DEMO off
# after the database is seeded if you do not want startup to refresh demo records.
AUTO_MIGRATE="false"
AUTO_SEED_DEMO="false"

# DATABASE_URL: PostgreSQL connection string for the Node.js API.
DATABASE_URL="postgres://user:password@localhost:5432/resource_tracker"

# PGSSLMODE: Set to require when connecting to a managed PostgreSQL instance that needs SSL.
PGSSLMODE="disable"

# SERVE_STATIC: Set to true in non-production environments when the API should serve dist/.
SERVE_STATIC="false"
